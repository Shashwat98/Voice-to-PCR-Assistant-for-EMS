# OpenAI API Key (required for Whisper ASR and GPT-4 baseline)
PCR_OPENAI_API_KEY=sk-...

# Anthropic API Key (optional, for Claude baseline)
PCR_ANTHROPIC_API_KEY=sk-ant-...

# Server
PCR_DEBUG=true
PCR_HOST=0.0.0.0
PCR_PORT=8000
PCR_CORS_ORIGINS=["http://localhost:3000"]

# Fine-tuned model
PCR_FINETUNED_MODEL_PATH=models/t5_pcr_v1
PCR_FINETUNED_MODEL_DEVICE=cpu
PCR_EXTRACTION_MODEL_DEFAULT=llm_baseline

# PCR State
PCR_CONFIDENCE_THRESHOLD=0.5
